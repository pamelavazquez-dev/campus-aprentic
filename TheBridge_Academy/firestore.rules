rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ----------------------------------------------------------------------
    // REGLAS POR DEFECTO
    // ----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------------------
    // GESTIÓN DE USUARIOS
    // ----------------------------------------------------------------------
    match /admin/{userId} {
      allow read, write: if request.auth != null && request.auth.token.rol == 'admin';
    }
    match /profesor/{userId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.token.rol == 'admin'; 
    }
    match /alumnos/{userId} {
      allow read: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor' || request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.token.rol == 'admin'; 
    }

    // ----------------------------------------------------------------------
    // ESTRUCTURA ACADÉMICA
    // ----------------------------------------------------------------------
    match /promociones/{promocionId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && request.auth.token.rol == 'admin'; 
    }
    match /modulos/{moduloId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor'); 
    }
    match /lecciones/{leccionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor'); 
    }
    match /inscripciones/{inscripcionId} {
      allow read: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor' || resource.data.alumnoId == request.auth.uid);
      allow write: if request.auth != null && request.auth.token.rol == 'admin'; 
    }

    // ----------------------------------------------------------------------
    // PROGRESO Y PARTICIPACIÓN
    // ----------------------------------------------------------------------
    match /notas/{alumnoId} {
      allow read: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor' || request.auth.uid == alumnoId);
      allow write: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor'); 
    }
    match /proyectos/{proyectoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor' || (request.auth.token.rol == 'alumno' && request.resource.data.alumnoId == request.auth.uid));
      allow update, delete: if request.auth != null && (request.auth.token.rol == 'admin' || request.auth.token.rol == 'profesor' || (request.auth.token.rol == 'alumno' && resource.data.alumnoId == request.auth.uid)); 
    }
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.token.rol == 'admin' || (request.auth.token.rol == 'alumno' && request.resource.data.alumnoId == request.auth.uid));
      allow update, delete: if request.auth != null && (request.auth.token.rol == 'admin' || (request.auth.token.rol == 'alumno' && resource.data.alumnoId == request.auth.uid)); 
    }
  }
}
