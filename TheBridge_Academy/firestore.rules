rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ----------------------------------------------------------------------
    // REGLAS POR DEFECTO
    // ----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------------------
    // GESTIÓN DE USUARIOS Y CAMPUS
    // ----------------------------------------------------------------------
    match /campus/{campusId} {
      allow read: if true; 
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    match /admin/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }
    
    match /profesores/{userId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }
    
    match /alumnos/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // ----------------------------------------------------------------------
    // ESTRUCTURA ACADÉMICA
    // ----------------------------------------------------------------------
    match /promociones/{promocionId} {
      allow read: if request.auth != null; 
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }
    
    match /modulos/{moduloId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || exists(/databases/$(database)/documents/profesores/$(request.auth.uid))); 
    }
    
    match /lecciones/{leccionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || exists(/databases/$(database)/documents/profesores/$(request.auth.uid))); 
    }
    
    match /inscripciones/{inscripcionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // ----------------------------------------------------------------------
    // PROGRESO Y PARTICIPACIÓN
    // ----------------------------------------------------------------------
    match /notas/{notaId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || exists(/databases/$(database)/documents/profesores/$(request.auth.uid))); 
    }
    
    match /proyectos/{proyectoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || exists(/databases/$(database)/documents/profesores/$(request.auth.uid)) || (exists(/databases/$(database)/documents/alumnos/$(request.auth.uid)) && request.resource.data.alumnoId == request.auth.uid));
      allow update, delete: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || exists(/databases/$(database)/documents/profesores/$(request.auth.uid)) || (exists(/databases/$(database)/documents/alumnos/$(request.auth.uid)) && resource.data.alumnoId == request.auth.uid)); 
    }
    
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || (exists(/databases/$(database)/documents/alumnos/$(request.auth.uid)) && request.resource.data.alumnoId == request.auth.uid));
      allow update, delete: if request.auth != null && (exists(/databases/$(database)/documents/admin/$(request.auth.uid)) || (exists(/databases/$(database)/documents/alumnos/$(request.auth.uid)) && resource.data.alumnoId == request.auth.uid)); 
    }
  }
}
